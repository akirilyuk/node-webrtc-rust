{
  "name": "@node-webrtc-rust/example-voice-agent-echo-pod",
  "private": true,
  "version": "0.6.2",
  "description": "SessionPod echo host — runner parent stack without runner or agent child IPC (layer isolation)",
  "type": "module",
  "scripts": {
    "start": "bash ../../scripts/export-sherpa-local-models.sh -- tsx src/index.ts",
