    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@node-webrtc-rust/helpers": "0.6.2",
    "@node-webrtc-rust/sdk": "0.6.2",
    "@node-webrtc-rust/signaling": "0.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
