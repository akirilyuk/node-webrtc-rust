{
  "name": "@node-webrtc-rust/example-voice-agent-local-sherpa",
  "private": true,
  "version": "0.6.2",
  "description": "Browser WebRTC + local Sherpa-ONNX STT/TTS (no cloud keys) with model download helpers and Node roundtrip demo",
  "type": "module",
  "scripts": {
    "download-stt": "node scripts/download-stt.mjs",
    "download-stt:list": "node scripts/download-stt.mjs --list",
    "download-stt:en": "node scripts/download-stt.mjs --lang=en",
    "download-stt:en-legacy": "node scripts/download-stt.mjs --lang=en-legacy",
    "download-stt:es": "node scripts/download-stt.mjs --lang=es",
    "download-stt:pt": "node scripts/download-stt.mjs --lang=pt",
    "download-stt:ar": "node scripts/download-stt.mjs --lang=ar",
    "download-stt:ru": "node scripts/download-stt.mjs --lang=ru",
    "download-stt:hi": "node scripts/download-stt.mjs --lang=hi",
    "download-stt:bn": "node scripts/download-stt.mjs --lang=bn",
    "download-stt:de": "node scripts/download-stt.mjs --lang=de",
    "download-stt:fr": "node scripts/download-stt.mjs --lang=fr",
    "download-stt:ja": "node scripts/download-stt.mjs --lang=ja",
    "download-stt:zh": "node scripts/download-stt.mjs --lang=zh",
    "download-stt:it": "node scripts/download-stt.mjs --lang=it",
    "download-tts": "node scripts/download-tts.mjs",
    "download-tts:list": "node scripts/download-tts.mjs --list",
    "download-tts:en": "node scripts/download-tts.mjs --lang=en",
    "download-tts:en-glados": "node scripts/download-tts.mjs --lang=en-glados",
    "download-tts:es": "node scripts/download-tts.mjs --lang=es",
    "download-tts:de": "node scripts/download-tts.mjs --lang=de",
    "download-tts:zh": "node scripts/download-tts.mjs --lang=zh",
    "download-all": "node scripts/download-all-sherpa.mjs",
    "download-all:minimal": "node scripts/download-all-sherpa.mjs --minimal",
    "start": "bash ../../scripts/export-sherpa-local-models.sh -- tsx src/index.ts",
    "start:roundtrip": "bash ../../scripts/export-sherpa-local-models.sh -- tsx src/roundtrip.ts",
    "start:roundtrip-counting": "bash ../../scripts/export-sherpa-local-models.sh -- tsx src/roundtrip-counting.ts",
    "start:roundtrip-counting-echo": "bash ../../scripts/export-sherpa-local-models.sh -- tsx src/roundtrip-counting-echo.ts",
    "start:roundtrip-counting-barge-recovery": "bash ../../scripts/export-sherpa-local-models.sh -- tsx src/roundtrip-counting-barge-recovery.ts",
    "start:roundtrip-utterance-timing": "bash ../../scripts/export-sherpa-local-models.sh -- tsx src/roundtrip-utterance-timing.ts",
    "start:roundtrip-two-phrases": "bash ../../scripts/export-sherpa-local-models.sh -- tsx src/roundtrip-two-phrases.ts",
    "start:roundtrip-barge-in": "bash ../../scripts/export-sherpa-local-models.sh -- tsx src/roundtrip-barge-in.ts",
    "start:roundtrip-concurrent-multi-client": "bash ../../scripts/export-sherpa-local-models.sh -- tsx src/roundtrip-concurrent-multi-client.ts",
    "start:debug": "VOICE_DEBUG=1 WEBRTC_DEBUG=1 bash ../../scripts/export-sherpa-local-models.sh -- tsx src/index.ts",
    "test": "vitest run",
    "test:roundtrip-counting": "vitest run src/roundtrip-counting.test.ts src/roundtrip-counting-echo.test.ts src/roundtrip-counting-barge-recovery.test.ts src/roundtrip-utterance-timing.test.ts src/roundtrip-two-phrases.test.ts src/roundtrip-barge-in.test.ts src/roundtrip-stt-lifecycle.test.ts src/roundtrip-concurrent-multi-client.test.ts",
    "test:roundtrip-barge-in": "vitest run src/roundtrip-barge-in.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@node-webrtc-rust/helpers": "0.6.2",
    "@node-webrtc-rust/sdk": "0.6.2",
    "@node-webrtc-rust/signaling": "0.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
