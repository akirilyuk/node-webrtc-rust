{
  "name": "@node-webrtc-rust/example-voice-agent-multi-session-pod",
  "private": true,
  "version": "0.5.2",
  "description": "One Node pod: single signaling entry point, many concurrent voice sessions (one VoiceAgent per WebRTC connection)",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "start:debug": "VOICE_DEBUG=1 WEBRTC_DEBUG=1 tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@node-webrtc-rust/helpers": "0.5.2",
    "@node-webrtc-rust/sdk": "0.5.2",
    "@node-webrtc-rust/signaling": "0.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
