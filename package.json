{
  "name": "node-webrtc-rust",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Rust-backed WebRTC native module for Node.js with audio/video mixing",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "install:all": "bash scripts/install-workspace.sh",
    "setup": "npm run install:all && npm run build:native && npm run build:ts",
    "build": "npm run build --workspaces --if-present",
    "build:native": "npm run build:debug:local --workspace=@node-webrtc-rust/bindings",
    "build:ts": "npm run build --workspace=@node-webrtc-rust/sdk --workspace=@node-webrtc-rust/signaling",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present",
    "test:rust": "cargo test --workspace",
    "test:ts": "npm run test --workspaces --if-present",
    "test:all": "bash scripts/run-all-tests.sh",
    "ci:docker:build": "docker build -t node-webrtc-rust-ci-build:local docker/ci",
    "ci:verify:linux": "bash scripts/ci/verify-linux.sh",
    "ci:verify:checks": "bash scripts/ci/verify-checks.sh",
    "ci:verify:checks:docker": "CI_VERIFY_CHECKS_IN_DOCKER=1 bash scripts/ci/verify-checks.sh",
    "ci:verify": "npm run ci:verify:linux && npm run ci:verify:checks:docker",
    "release:local": "bash scripts/release-local.sh",
    "release:publish": "bash scripts/release-publish.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
