{
  "name": "node-webrtc-rust",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Rust-backed WebRTC native module for Node.js with audio/video mixing",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:ts": "npm run build --workspace=@node-webrtc-rust/sdk --workspace=@node-webrtc-rust/signaling --workspace=@node-webrtc-rust/conference",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
