{
  "name": "@node-webrtc-rust/bindings",
  "version": "0.6.8",
  "description": "NAPI-RS native bindings for node-webrtc-rust — WebRTC peer connections, data channels, and conference audio mixing",
  "keywords": [
    "webrtc",
    "native",
    "napi",
    "napi-rs",
    "rust",
    "node-addon",
    "node-native",
    "prebuild",
    "bindings",
    "rtcpeerconnection",
    "datachannel",
    "conference",
    "audio-mixing",
    "mcu",
    "nodejs"
  ],
  "homepage": "https://github.com/akirilyuk/node-webrtc-rust#readme",
  "bugs": {
    "url": "https://github.com/akirilyuk/node-webrtc-rust/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akirilyuk/node-webrtc-rust.git",
    "directory": "packages/bindings"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "node-webrtc-rust",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "scripts": {
    "build": "npm run build:local",
    "build:local": "napi build --release && npm run copy:local-node",
    "build:debug:local": "napi build && npm run copy:local-node",
    "copy:local-node": "node scripts/copy-local-node.mjs",
    "build:all": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version"
  },
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "optionalDependencies": {
    "@node-webrtc-rust/bindings-win32-x64-msvc": "0.6.8",
    "@node-webrtc-rust/bindings-darwin-x64": "0.6.8",
    "@node-webrtc-rust/bindings-linux-x64-gnu": "0.6.8",
    "@node-webrtc-rust/bindings-darwin-arm64": "0.6.8",
    "@node-webrtc-rust/bindings-linux-arm64-gnu": "0.6.8",
    "@node-webrtc-rust/bindings-linux-x64-musl": "0.6.8"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ]
}
