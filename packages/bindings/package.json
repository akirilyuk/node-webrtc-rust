{
  "name": "@node-webrtc-rust/bindings",
  "version": "0.1.0",
  "description": "NAPI-RS native bindings for node-webrtc-rust",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "node-webrtc-rust",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version"
  },
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "optionalDependencies": {
    "@node-webrtc-rust/bindings-darwin-arm64": "0.1.0",
    "@node-webrtc-rust/bindings-darwin-x64": "0.1.0",
    "@node-webrtc-rust/bindings-linux-x64-gnu": "0.1.0",
    "@node-webrtc-rust/bindings-linux-x64-musl": "0.1.0",
    "@node-webrtc-rust/bindings-linux-arm64-gnu": "0.1.0",
    "@node-webrtc-rust/bindings-win32-x64-msvc": "0.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ]
}
