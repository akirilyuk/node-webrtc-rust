{
  "name": "@node-webrtc-rust/conference-bindings",
  "version": "0.1.0",
  "description": "NAPI-RS native bindings for node-webrtc-rust conference APIs",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "node-webrtc-rust-conference",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "scripts": {
    "build": "npm run build:local",
    "build:local": "napi build --release && npm run copy:local-node",
    "build:debug:local": "napi build && npm run copy:local-node",
    "copy:local-node": "node scripts/copy-local-node.mjs",
    "build:all": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "version": "napi version"
  },
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ]
}
