{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "CommonJS",
    "lib": ["ES2022"],
    "baseUrl": "../..",
    "paths": {
      "@node-webrtc-rust/bindings": ["packages/bindings/index.d.ts"],
      "@node-webrtc-rust/sdk": ["packages/sdk/src/index.ts"],
      "@node-webrtc-rust/sdk/*": ["packages/sdk/src/*"],
      "@node-webrtc-rust/signaling": ["packages/signaling/src/index.ts"],
      "@node-webrtc-rust/helpers": ["packages/helpers/src/index.ts"],
      "@node-webrtc-rust/helpers/*": ["packages/helpers/src/*"]
    }
  },
  "include": [
    "../../packages/sdk/src/**/*.ts",
    "../../packages/signaling/src/**/*.ts",
    "../../packages/helpers/src/**/*.ts"
  ],
  "exclude": ["../../packages/**/tests/**", "../../packages/**/node_modules/**"]
}
